FROM node:20-bookworm-slim
ARG DEBIAN_FRONTEND=noninteractive

# the dev compose stack bind-mounts the repo over /double-take (keeping the
# container's api/frontend node_modules via anonymous volumes), so this image
# only pre-installs dependencies
WORKDIR /double-take/api
COPY api/package.json api/package-lock.json ./
RUN npm ci --omit=dev

WORKDIR /double-take/frontend
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

RUN mkdir /.storage && ln -s /.storage /double-take/.storage

ENV NODE_ENV=development
WORKDIR /double-take
